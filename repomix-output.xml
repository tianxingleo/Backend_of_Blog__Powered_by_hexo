      }

      const close = () => {
        $crisp.push(["do", "chat:hide"])
      }

      close()
      $crisp.push(["on", "chat:closed", function() {
        close()
      }])

      window.chatBtnFn = () => {
        $crisp.is("chat:visible") ? close() : open()
      }
    } else if (isChatHideShow) {
      window.chatBtn = {
        hide: () => {
          $crisp.push(["do", "chat:hide"])
        },
        show: () => {
          $crisp.push(["do", "chat:show"])
        }
      }
    }
  })()
