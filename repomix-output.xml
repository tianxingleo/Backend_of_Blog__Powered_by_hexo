script.
  (() => {
    window.$crisp = [];
    window.CRISP_WEBSITE_ID = "!{theme.crisp.website_id}";
    (function () {
      d = document;
      s = d.createElement("script");
      s.src = "https://client.crisp.chat/l.js";
      s.async = 1;
      d.getElementsByTagName("head")[0].appendChild(s);
    })();
    $crisp.push(["safe", true])

