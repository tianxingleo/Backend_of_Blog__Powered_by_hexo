      cursor: pointer;
      .anzhiyufont .anzhiyu-icon-arrow-circle-right 
        font-size: 1.3rem;
        margin-right: 10px;

    .author-info-avatar 
      user-select: none
      img
        filter: blur(0) brightness(1);
      .author-status
