          el: '#vcomment',
          appId: '#{theme.valine.appId}',
          appKey: '#{theme.valine.appKey}',
          serverURLs: '#{theme.valine.serverURLs}'
        }
        
        const valine = new Valine(initData)
      }

      if (typeof Valine === 'function') initValine() 
