#aside-content #card-toc:hover .toc-content .toc-link:not(.active) span {
  filter: blur(0);
  opacity: 1;
}
#aside-content #card-toc .toc-content .toc-link:not(.active) span:hover {
  color: var(--anzhiyu-lighttext);
