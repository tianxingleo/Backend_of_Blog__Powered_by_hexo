              randomPostTimes += 1;
              localStorage.setItem("randomPostTimes", randomPostTimes);
              document.querySelector(".random-post-start").style.opacity = "1";
            }, randomTime);
          }
        });
      randomPostWorking = false;
    }
  }
}

