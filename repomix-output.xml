        "",
        "color:#425AEF",
        "color:#425AEF",
        "",
        "color:#425AEF",
        ""
      )
    );
    setTimeout(
      Log.bind(
        console,
        `%c ${ascll2[0]} %c ${ascll2[1]} %c \n${ascll2[2]} %c\n${ascll2[3]}\n`,
        "color:white; background-color:#4fd953",
        "",
