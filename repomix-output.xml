          labels: "question"
          inactive-day: 60
          close-reason: "not_planned"
          body: |
            Hello @${{ github.event.issue.user.login }}, this issue was closed due to no activities in 60 days.
            你好 @${{ github.event.issue.user.login }}，此issue因超过60天未回复被关闭。
</file>

